// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ServiceType {
  CUSTOM_DESIGN
  ALTERATION
  RENTAL_FITTING
}

enum ReservationStatus {
  CONFIRMED
  RELEASED
}

enum PolicyType {
  TERMS
  PRIVACY
}

enum CalendarSyncStatus {
  NOT_SYNCED
  SYNCED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RentalItem {
  id          String                  @id @default(uuid())
  name        String
  description String
  size        String?
  price       Decimal                 @db.Decimal(10, 2)
  imageUrl    String?
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  items       BookingItem[]
  reservations RentalItemReservation[]
}

model Booking {
  id                  String                  @id @default(uuid())
  referenceCode       String                  @unique
  status              BookingStatus           @default(CONFIRMED)
  serviceType         ServiceType
  clientName          String
  clientEmail         String
  clientPhone         String
  startAtUtc          DateTime
  endAtUtc            DateTime
  timezone            String
  notes               String?
  specialRequests     String?
  calendarSyncStatus  CalendarSyncStatus      @default(NOT_SYNCED)
  termsVersionId      String
  privacyVersionId    String
  managementTokenHash String?
  managementTokenUsed Boolean                 @default(false)
  cancelledAt         DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  bookingItems        BookingItem[]
  itemReservations    RentalItemReservation[]
  termsVersion        PolicyVersion           @relation("TermsAccepted", fields: [termsVersionId], references: [id])
  privacyVersion      PolicyVersion           @relation("PrivacyAccepted", fields: [privacyVersionId], references: [id])
  calendarEvent       CalendarEvent?
  emailLogs           EmailLog[]

  @@index([startAtUtc, status])
}

model BookingItem {
  id           String     @id @default(uuid())
  bookingId    String
  rentalItemId String
  quantity     Int        @default(1)
  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rentalItem   RentalItem @relation(fields: [rentalItemId], references: [id], onDelete: Restrict)

  @@unique([bookingId, rentalItemId])
}

model RentalItemReservation {
  id           String            @id @default(uuid())
  rentalItemId String
  bookingId    String
  startAtUtc   DateTime
  endAtUtc     DateTime
  status       ReservationStatus @default(CONFIRMED)
  rentalItem   RentalItem        @relation(fields: [rentalItemId], references: [id], onDelete: Restrict)
  booking      Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([rentalItemId, startAtUtc, endAtUtc])
}

model PolicyDocument {
  id        String          @id @default(uuid())
  type      PolicyType      @unique
  title     String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  versions  PolicyVersion[]
}

model PolicyVersion {
  id              String         @id @default(uuid())
  documentId      String
  versionNumber   Int
  contentMarkdown String
  isActive        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  document        PolicyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  acceptedAsTerms Booking[]      @relation("TermsAccepted")
  acceptedAsPrivacy Booking[]    @relation("PrivacyAccepted")

  @@unique([documentId, versionNumber])
}

model CalendarConnection {
  id                    String   @id @default(uuid())
  googleCalendarId      String
  encryptedRefreshToken String
  connectedAt           DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model CalendarEvent {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  googleEventId String   @unique
  etag          String?
  syncedAt      DateTime @default(now())
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id         String   @id @default(uuid())
  bookingId  String
  template   String
  recipient  String
  providerId String?
  status     String
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model AvailabilityRule {
  id              String   @id @default(uuid())
  weekday         Int
  startMinutes    Int
  endMinutes      Int
  slotIntervalMin Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([weekday])
}

model BlackoutPeriod {
  id         String   @id @default(uuid())
  startAtUtc DateTime
  endAtUtc   DateTime
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([startAtUtc, endAtUtc])
}
